{% extends 'base.html.twig' %}

{% block title %}Notes{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 p-6">

    <div class="max-w-5xl mx-auto space-y-6">

        <!-- Header -->
        <div class="text-center">
            <h1 class="text-3xl font-bold text-gray-800">Notes</h1>
            <p class="text-gray-500">Manage your notes efficiently</p>
        </div>

        <!-- Add Note Card -->
        <div class="bg-white rounded-2xl shadow-xl p-6">
            <h2 class="text-xl font-semibold mb-4">Add New Note</h2>

            <form method="post" action="{{ path('app_notes_new') }}" class="space-y-4">

                <div>
                    <label class="block text-sm font-medium mb-1">Title</label>
                    <input name="title" type="text"
                           class="w-full px-4 py-2 border rounded-lg"
                           placeholder="e.g. Meeting notes" required>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1">Content</label>
                    <textarea name="content" rows="4"
                              class="w-full px-4 py-2 border rounded-lg"
                              placeholder="Write your note..." required></textarea>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                    <div>
                        <label class="block text-sm font-medium mb-1">Status</label>
                        <select name="status" class="w-full px-4 py-2 border rounded-lg">
                            {% for value, label in statuses %}
                                <option value="{{ value }}">{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium mb-1">Category</label>
                        <select id="categorySelect" name="category"
                                class="w-full px-4 py-2 border rounded-lg">
                            {% for value in categories %}
                                <option value="{{ value }}">{{ value }}</option>
                            {% endfor %}
                            <option value="__custom__">Custom</option>
                        </select>

                        <input id="customCategory"
                               name="custom_category"
                               type="text"
                               placeholder="Custom category"
                               class="w-full mt-2 px-4 py-2 border rounded-lg hidden">
                    </div>
                </div>

                <button type="submit"
                        class="w-full bg-gradient-to-r from-blue-500 to-indigo-600 text-white py-3 rounded-lg font-semibold">
                    Add Note
                </button>
            </form>
        </div>

        <!-- Filters -->
        <div class="bg-white rounded-2xl shadow-xl p-6">
            <form method="get" action="{{ path('app_notes') }}"
                  class="grid grid-cols-1 md:grid-cols-4 gap-4">

                <input name="q" type="text"
                       value="{{ query.q|default('') }}"
                       placeholder="Search..."
                       class="px-4 py-2 border rounded-lg">

                <select name="status" class="px-4 py-2 border rounded-lg">
                    <option value="all">All Status</option>
                    {% for value, label in statuses %}
                        <option value="{{ value }}" {% if query.status == value %}selected{% endif %}>
                            {{ label }}
                        </option>
                    {% endfor %}
                </select>

                <select name="category" class="px-4 py-2 border rounded-lg">
                    <option value="all">All Categories</option>
                    {% for value in categories %}
                        <option value="{{ value }}" {% if query.category == value %}selected{% endif %}>
                            {{ value }}
                        </option>
                    {% endfor %}
                </select>

                <div class="flex gap-2">
                    <button type="submit"
                            class="flex-1 bg-blue-500 text-white rounded-lg">
                        Search
                    </button>
                    <a href="{{ path('app_notes') }}"
                       class="flex-1 text-center border rounded-lg py-2">
                        Reset
                    </a>
                </div>
            </form>
        </div>

        <!-- Summary -->
        <div class="text-gray-600 text-sm">
            Showing {{ notes|length }} note{% if notes|length != 1 %}s{% endif %}
        </div>

        <!-- Notes List -->
        <div class="grid gap-4">

            {% for note in notes %}
                <div class="bg-white rounded-xl shadow p-5 relative">
                    
                    <div class="flex mr-2 items-center mb-2">
                        <span class="text-xs mr-2 px-2 py-1 bg-gray-100 rounded">
                            {{ note.category }}
                        </span>
                        <span class="text-xs px-2 py-1 bg-blue-100 text-blue-600 rounded">
                            {{ statuses[note.status] }}
                        </span>
                    </div>
                    <form method="post"
                        action="{{ path('app_notes_delete', {id: note.id}) }}"
                        onsubmit="return confirm('Delete this note?');"
                        class="absolute top-3 right-3">

                        <input type="hidden" name="_token" value="{{ csrf_token('delete_note_' ~ note.id) }}">

                        <button class="text-red-500 hover:text-red-700 text-sm">
                            ✕
                        </button>
                    </form>

                    <h3 class="text-lg font-semibold text-gray-800">
                        {{ note.title }}
                    </h3>

                    <p class="text-gray-600 text-sm mt-2">
                        {{ note.content|nl2br }}
                    </p>
                </div>
            {% else %}
                <div class="text-center text-gray-500 py-10">
                    No notes match your filters.
                </div>
            {% endfor %}

        </div>

    </div>
</div>

<!-- Small JS for custom category -->
<script>
    const categorySelect = document.getElementById('categorySelect');
    const customInput = document.getElementById('customCategory');

    categorySelect.addEventListener('change', () => {
        if (categorySelect.value === '__custom__') {
            customInput.classList.remove('hidden');
        } else {
            customInput.classList.add('hidden');
        }
    });
</script>

{% endblock %}